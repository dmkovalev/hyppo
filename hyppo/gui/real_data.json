    "hypotheses": [
      {
        "id": "h_CRM",
        "label": "DualTau CRM — физическая ветвь: доли связности и постоянные времени",
        "branch": "LPR",
        "description": "DualTau CRM -- physics branch: connectivity fractions and time constants",
        "model": "m_phys_8",
        "model_classes": [
          "PhysicsModel",
          "Model",
          "Artefact",
          "Thing"
        ],
        "hyperparam_axes": [
          "USE_DUAL_TAU_CRM",
          "CRM_KNN",
          "PHYS_GRAD_MODE"
        ],
        "equation": {
          "formula": "q_liq = f_ij * I_inj",
          "output": "q_liq"
        },
        "variables": [
          "I_inj",
          "f_ij",
          "q_liq"
        ]
      },
      {
        "id": "h_ML",
        "label": "Transformer+GNN — ML-ветвь: временные и пространственные признаки",
        "branch": "LPR",
        "description": "Transformer+GNN -- ML branch: temporal and spatial feature learning",
        "model": "m_dd_9",
        "model_classes": [
          "DataDrivenModel",
          "Model",
          "Artefact",
          "Thing"
        ],
        "hyperparam_axes": [
          "HIDDEN_DIM",
          "GNN_NUM_LAYERS",
          "GNN_HEADS",
          "TRANSFORMER_NUM_LAYERS",
          "TRANSFORMER_NHEAD",
          "DIM_FEEDFORWARD_MULT",
          "BIDIRECTIONAL",
          "USE_TEMPORAL_EDGE_FEATURES"
        ],
        "equation": {
          "formula": "l_ml = W_ml * x_feat",
          "output": "l_ml"
        },
        "variables": [
          "W_ml",
          "l_ml",
          "x_feat"
        ]
      },
      {
        "id": "h_LPR",
        "label": "Fusion gate — слияние физического и ML-прогнозов жидкости",
        "branch": "LPR",
        "description": "Fusion gate -- combines physics and ML liquid production predictions",
        "model": "m_hybrid_10",
        "model_classes": [
          "HybridModel",
          "Model",
          "Artefact",
          "Thing"
        ],
        "hyperparam_axes": [
          "USE_FUSION_GATE"
        ],
        "equation": {
          "formula": "l = g * q_liq + (1 - g) * l_ml",
          "output": "l"
        },
        "variables": [
          "g",
          "l",
          "l_ml",
          "q_liq"
        ]
      },
      {
        "id": "h_MB",
        "label": "Материальный баланс — обновление водонасыщенности",
        "branch": "WCT",
        "description": "Material balance -- water saturation update from predicted production",
        "model": "m_phys_mb_11",
        "model_classes": [
          "PhysicsModel",
          "Model",
          "Artefact",
          "Thing"
        ],
        "hyperparam_axes": [
          "USE_MATERIAL_BALANCE"
        ],
        "equation": {
          "formula": "Sw = Swp + (W_inj - l) * dt / Vp",
          "output": "Sw"
        },
        "variables": [
          "Sw",
          "Swp",
          "Vp",
          "W_inj",
          "dt",
          "l"
        ]
      },
      {
        "id": "h_BL",
        "label": "Buckley–Leverett — доля воды из профиля насыщенности",
        "branch": "WCT",
        "description": "Buckley-Leverett -- fractional flow from saturation profile",
        "model": "m_phys_bl_12",
        "model_classes": [
          "PhysicsModel",
          "Model",
          "Artefact",
          "Thing"
        ],
        "hyperparam_axes": [
          "BATCH_SIZE",
          "BACKPERIOD"
        ],
        "equation": {
          "formula": "fw = ((Sw - Swc) / (1 - Swc - Sor)) ** nw",
          "output": "fw"
        },
        "variables": [
          "Sor",
          "Sw",
          "Swc",
          "fw",
          "nw"
        ]
      },
      {
        "id": "h_WCT",
        "label": "WCT-anchoring — коррекция обводнённости по физике и ML",
        "branch": "WCT",
        "description": "WCT-anchoring -- water cut correction using physics and ML context",
        "model": "m_hybrid_wct_13",
        "model_classes": [
          "HybridModel",
          "Model",
          "Artefact",
          "Thing"
        ],
        "hyperparam_axes": [
          "USE_CRM_PHASE",
          "CRM_PHASE_RATIO"
        ],
        "equation": {
          "formula": "wct = a_bl * fw + a_ml * l_ml",
          "output": "wct"
        },
        "variables": [
          "a_bl",
          "a_ml",
          "fw",
          "l_ml",
          "wct"
        ]
      }
    ],
