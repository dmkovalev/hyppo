    "nodes": [
      {
        "id": "H1",
        "label": "Агрегация закачки",
        "branch": "жидкость",
        "equation": {
          "formula": "I_agg = w_ij * I_j",
          "output": "I_agg"
        },
        "model": "m_crmp",
        "status": "SUPPORTED"
      },
      {
        "id": "H2",
        "label": "CRM быстрый канал",
        "branch": "жидкость",
        "equation": {
          "formula": "q_f = a_f*q_f_prev + b_f*I_agg",
          "output": "q_f"
        },
        "model": "m_crmp",
        "status": "SUPPORTED"
      },
      {
        "id": "H3",
        "label": "CRM медленный канал",
        "branch": "жидкость",
        "equation": {
          "formula": "q_s = a_s*q_s_prev + b_s*I_agg",
          "output": "q_s"
        },
        "model": "m_crmp",
        "status": "SUPPORTED"
      },
      {
        "id": "H4",
        "label": "Смешение каналов",
        "branch": "жидкость",
        "equation": {
          "formula": "q_c = w_f*q_f + (1-w_f)*q_s",
          "output": "q_c"
        },
        "model": "m_crmp",
        "status": "SUPPORTED"
      },
      {
        "id": "H5",
        "label": "Продуктивность",
        "branch": "жидкость",
        "equation": {
          "formula": "q_liq_phys = J*q_c + q_prim",
          "output": "q_liq_phys"
        },
        "model": "m_crmp",
        "status": "SUPPORTED"
      },
      {
        "id": "H6",
        "label": "Первичная добыча (спад)",
        "branch": "жидкость",
        "equation": {
          "formula": "q_prim = q_prev*exp(-dt*taup)",
          "output": "q_prim"
        },
        "model": "m_crmp",
        "status": "SUPPORTED"
      },
      {
        "id": "H7",
        "label": "ML-коррекция (MLP)",
        "branch": "жидкость",
        "equation": {
          "formula": "l_ml = MLP(x_hist)",
          "output": "l_ml"
        },
        "model": "m_nn",
        "status": "SUPPORTED"
      },
      {
        "id": "H8",
        "label": "LPR Fusion (вентиль g)",
        "branch": "жидкость",
        "equation": {
          "formula": "l = g*q_liq_phys + (1-g)*l_ml",
          "output": "l"
        },
        "model": "m_hyb",
        "status": "SUPPORTED"
      },
      {
        "id": "H9",
        "label": "Материальный баланс",
        "branch": "обводнённость",
        "equation": {
          "formula": "Sw = Sw_prev + (Winj - Wlout)*dt/Vp",
          "output": "Sw"
        },
        "model": "m_bl",
        "status": "SUPPORTED"
      },
      {
        "id": "H10",
        "label": "Corey krw",
        "branch": "обводнённость",
        "equation": {
          "formula": "krw = ((Sw-Swc)/(1-Swc-Sor))**nw",
          "output": "krw"
        },
        "model": "m_bl",
        "status": "SUPPORTED"
      },
      {
        "id": "H11",
        "label": "Corey kro",
        "branch": "обводнённость",
        "equation": {
          "formula": "kro = ((1-Sw-Sor)/(1-Swc-Sor))**no",
          "output": "kro"
        },
        "model": "m_bl",
        "status": "SUPPORTED"
      },
      {
        "id": "H12",
        "label": "Баклея–Леверетта fw",
        "branch": "обводнённость",
        "equation": {
          "formula": "fw = 1/(1 + kro*muw/(krw*muo))",
          "output": "fw"
        },
        "model": "m_bl",
        "status": "SUPPORTED"
      },
      {
        "id": "H13",
        "label": "WCT-якорь (физика)",
        "branch": "обводнённость",
        "equation": {
          "formula": "o_p = 1 - fw",
          "output": "o_p"
        },
        "model": "m_bl",
        "status": "SUPPORTED"
      },
      {
        "id": "H14",
        "label": "WCT Fusion",
        "branch": "обводнённость",
        "equation": {
          "formula": "o = gw*o_p + (1-gw)*o_m",
          "output": "o"
        },
        "model": "m_hyb",
        "status": "SUPPORTED"
      },
      {
        "id": "H15",
        "label": "ГРП (модуляция)",
        "branch": "ГТМ",
        "equation": {
          "formula": "J = J0 + dJ_grp",
