    "nodes": [
      {
        "id": "H1",
        "label": "Агрегация закачки",
        "branch": "LPR",
        "status": "SUPPORTED",
        "equation": {
          "formula": "I_agg = w_ij * I_j",
          "output": "I_agg"
        },
        "model": "m_phys"
      },
      {
        "id": "H2",
        "label": "CRM быстрый канал (τ_fast)",
        "branch": "LPR",
        "status": "SUPPORTED",
        "equation": {
          "formula": "q_f = a_f * q_f_prev + b_f * I_agg",
          "output": "q_f"
        },
        "model": "m_phys"
      },
      {
        "id": "H3",
        "label": "CRM медленный канал (τ_slow)",
        "branch": "LPR",
        "status": "SUPPORTED",
        "equation": {
          "formula": "q_s = a_s * q_s_prev + b_s * I_agg",
          "output": "q_s"
        },
        "model": "m_phys"
      },
      {
        "id": "H4",
        "label": "Смешение каналов",
        "branch": "LPR",
        "status": "SUPPORTED",
        "equation": {
          "formula": "q_c = w_f * q_f + (1 - w_f) * q_s",
          "output": "q_c"
        },
        "model": "m_phys"
      },
      {
        "id": "H5",
        "label": "Продуктивность",
        "branch": "LPR",
        "status": "SUPPORTED",
        "equation": {
          "formula": "q = J * q_c * (1 - d) ** t + q_b",
          "output": "q"
        },
        "model": "m_phys"
      },
      {
        "id": "H6",
        "label": "Transformer (временное внимание)",
        "branch": "LPR",
        "status": "SUPPORTED",
        "equation": {
          "formula": "h_t = Attn(q, x_t)",
          "output": "h_t"
        },
        "model": "m_ml"
      },
      {
        "id": "H7",
        "label": "GNN (пространственное внимание)",
        "branch": "LPR",
        "status": "SUPPORTED",
        "equation": {
          "formula": "h_s = GNN(q, Gconn)",
          "output": "h_s"
        },
        "model": "m_ml"
      },
      {
        "id": "H8",
        "label": "LPR-якорь (физика)",
        "branch": "LPR",
        "status": "SUPPORTED",
        "equation": {
          "formula": "l_p = q + delta",
          "output": "l_p"
        },
        "model": "m_hyb"
      },
      {
        "id": "H9",
        "label": "ML-коррекция жидкости",
        "branch": "LPR",
        "status": "SUPPORTED",
        "equation": {
          "formula": "l_m = MLP(h_t, h_s)",
          "output": "l_m"
        },
        "model": "m_ml"
      },
      {
        "id": "H10",
        "label": "LPR Fusion (вентиль g)",
        "branch": "LPR",
        "status": "SUPPORTED",
        "equation": {
          "formula": "l = g * l_p + (1 - g) * l_m",
          "output": "l"
        },
        "model": "m_hyb"
      },
      {
        "id": "H11",
        "label": "Corey (фазовые проницаемости)",
        "branch": "WCT",
        "status": "SUPPORTED",
        "equation": {
          "formula": "krw = Sw ** n",
          "output": "krw"
        },
        "model": "m_phys"
      },
      {
        "id": "H12",
        "label": "Баклея–Леверетта",
        "branch": "WCT",
        "status": "SUPPORTED",
        "equation": {
          "formula": "fw_bl = 1 / (1 + k_o / (M * krw))",
          "output": "fw_bl"
        },
        "model": "m_phys"
      },
      {
        "id": "H13",
        "label": "Нефтяная доля",
        "branch": "WCT",
        "status": "SUPERSEDED",
        "equation": {
          "formula": "fo = f_0 * exp(-Q_cum / tau)",
          "output": "fo"
        },
        "model": "m_phys"
      },
      {
        "id": "H14",
        "label": "Материальный баланс",
        "branch": "WCT",
        "status": "SUPPORTED",
        "equation": {
          "formula": "dSw = dt * (W_in - W_out) / V_p + fw_bl",
          "output": "dSw"
        },
        "model": "m_phys"
      },
      {
        "id": "H15",
        "label": "Log-WOR",
        "branch": "WCT",
        "status": "SUPERSEDED",
        "equation": {
          "formula": "wor = a + b * sum_I",
          "output": "wor"
        },
        "model": "m_phys"
      },
      {
        "id": "H16",
        "label": "BL/WOR смешение",
        "branch": "WCT",
        "status": "SUPPORTED",
        "equation": {
          "formula": "fw = c1 * fo + c2 * dSw + c3 * wor",
          "output": "fw"
        },
        "model": "m_hyb"
      },
      {
        "id": "H17",
        "label": "WCT-якорь (физика)",
        "branch": "WCT",
        "status": "SUPPORTED",
        "equation": {
          "formula": "o_p = (1 - fw) + delta",
          "output": "o_p"
        },
        "model": "m_phys"
      },
      {
        "id": "H18",
        "label": "WCT Fusion",
        "branch": "WCT",
        "status": "SUPPORTED",
        "equation": {
          "formula": "o = g_w * o_p + (1 - g_w) * o_m",
          "output": "o"
        },
        "model": "m_hyb"
      },
      {
        "id": "H19",
        "label": "OPR — прогноз нефти",
